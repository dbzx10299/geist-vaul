{
  "name": "geist-vaul",
  "version": "1.0.8",
  "description": "A minimal drawer component for Vue",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "drawer",
    "dialog",
    "modal"
  ],
  "homepage": "https://github.com/dbzx10299/geist-vaul#readme",
  "bugs": {
    "url": "https://github.com/dbzx10299/geist-vaul/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbzx10299/geist-vaul.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "author": "David Bender <https://github.com/dbzx10299>",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "reka-ui": "^2.9.2",
    "vue-remove-scroll": "^1.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsdown/css": "^0.21.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.0",
    "bumpp": "^11.0.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "unplugin-vue": "^7.1.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  }
}
